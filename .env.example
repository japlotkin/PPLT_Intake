# PPLT Intake Dashboard env variables
# Fill these in on Vercel; do not commit real values.

# --- GHL ---
GHL_ABOGADO_LOCATION_ID=
GHL_ABOGADO_PIT_TOKEN=
GHL_ABOGADO_V1_JWT=

GHL_PPLT_LOCATION_ID=
GHL_PPLT_PIT_TOKEN=
GHL_PPLT_V1_JWT=

# --- Meta Ads ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_PPLT=
META_AD_ACCOUNT_WORKERS_COMP=
META_AD_ACCOUNT_ABOGADO=

# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Site gate ---
# bcrypt hash of the shared firm password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PW',12))"
SITE_GATE_PASSWORD_HASH=
# random 32+ byte hex string; rotate to invalidate all gate sessions
SITE_GATE_COOKIE_SECRET=

# --- Cache (Vercel KV / Upstash) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Admin ---
ADMIN_EMAIL=jplotkin@pinderplotkin.com
